# Copy this file to .env and fill in real values. The .env file is gitignored.

# MapTiler API key — required for the 3D terrain map view on property pages.
# Register a free account at https://www.maptiler.com/cloud/ and create a key.
# Free tier supports terrain-RGB tiles for the 3D hillshade view.
MAPTILER_KEY=

# Optional: privacy-friendly analytics domain (Plausible or Fathom).
# Leave blank to keep the analytics snippet disabled.
ANALYTICS_DOMAIN=

# Eleventy build environment. Set to "production" for public builds.
ELEVENTY_ENV=development
