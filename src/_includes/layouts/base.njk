<!doctype html>
<html lang="en-US">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">

  {#- Page title — each page supplies its own, capped at 60 chars -#}
  <title>{{ meta_title or title }} | Goldstone LLC</title>

  {#- Description — each page supplies a hand-written meta_description -#}
  {% if meta_description %}
  <meta name="description" content="{{ meta_description }}">
  {% endif %}

  {#- Canonical -#}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  {#- Open Graph -#}
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ meta_title or title }}">
  {% if meta_description %}<meta property="og:description" content="{{ meta_description }}">{% endif %}
  <meta property="og:type" content="{{ og_type or 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}{{ og_image or site.default_meta.image }}">
  <meta property="og:locale" content="en_US">

  {#- Twitter Card -#}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ meta_title or title }}">
  {% if meta_description %}<meta name="twitter:description" content="{{ meta_description }}">{% endif %}
  <meta name="twitter:image" content="{{ site.url }}{{ og_image or site.default_meta.image }}">

  {#- Preconnect to font CDN -#}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">

  {#- Fonts -#}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"></noscript>

  {#- Stylesheets -#}
  {% set core_css = [
    "/assets/css/tokens.css",
    "/assets/css/reset.css",
    "/assets/css/typography.css",
    "/assets/css/layout.css",
    "/assets/css/components.css"
  ] %}
  {% for href in core_css %}
  <link rel="stylesheet" href="{{ href }}">
  {% endfor %}
  {% if extra_css %}{% for href in extra_css %}
  <link rel="stylesheet" href="{{ href }}">
  {% endfor %}{% endif %}

  {#- Analytics placeholder — uncomment once client sets up Plausible/Fathom -#}
  {#- TODO: <script defer data-domain="{{ site.domain }}" src="https://plausible.io/js/script.js"></script> -#}

  {#- Organization schema (every page) -#}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/assets/img/logo-goldstone.svg",
    "foundingDate": "{{ site.since }}",
    "founder": {
      "@type": "Person",
      "name": "{{ site.principal.name }}",
      "jobTitle": "{{ site.principal.role | safe }}"
    },
    "telephone": "{{ site.contact.phones[0] }}",
    "email": "{{ site.contact.email }}",
    "areaServed": {
      "@type": "State",
      "name": "Nevada",
      "containedInPlace": { "@type": "Country", "name": "US" }
    },
    "address": [
      {% for office in site.offices %}
      {
        "@type": "PostalAddress",
        "addressLocality": "{{ office.city }}",
        "addressRegion": "{{ office.state }}",
        "postalCode": "{{ office.postal }}",
        "addressCountry": "US"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>

  {#- Per-page structured data injected by child templates -#}
  {% block schema %}{% endblock %}

  {#- Preloader gate: runs before body parses so first-paint either shows
      the preloader or skips it without a flash. Skips for one hour after
      the most recent display per visitor (localStorage). -#}
  <script>
    (function(){
      try {
        var ts = Number(window.localStorage.getItem("goldstone_preloader_ts")) || 0;
        if (ts && (Date.now() - ts) < 3600000) {
          document.documentElement.classList.add("preloader-skip");
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>
  {#- Preloader overlay (2s, once per hour). -#}
  <div class="preloader" id="preloader" role="status" aria-label="Loading Goldstone LLC">
    <div class="preloader__inner">
      <svg class="preloader__mark" width="96" height="58" viewBox="0 0 56 34" aria-hidden="true">
        <path d="M2 27 L20 6 L36 27" fill="none" stroke="var(--copper)" stroke-width="6" stroke-linecap="butt" stroke-linejoin="miter" />
        <path d="M20 27 L36 9 L54 27" fill="none" stroke="var(--copper)" stroke-width="6" stroke-linecap="butt" stroke-linejoin="miter" />
      </svg>
      <span class="preloader__wordmark">Goldstone LLC</span>
      <span class="preloader__strapline">Since 1989</span>
    </div>
  </div>

  {#- Skip link (a11y) -#}
  <a class="skip-link" href="#main-content">Skip to main content</a>

  {% include "partials/header.njk" %}

  <main id="main-content" tabindex="-1">
    {% block content %}
      {{ content | safe }}
    {% endblock %}
  </main>

  {% include "partials/footer.njk" %}

  {#- Per-page scripts -#}
  {% if extra_js %}{% for src in extra_js %}
  <script src="{{ src }}" defer></script>
  {% endfor %}{% endif %}

  {#- Preloader controller: holds for 2s on first display, fades out, and
      stamps localStorage so the next hour of page loads skip it. -#}
  <script>
    (function(){
      var pre = document.getElementById("preloader");
      if (!pre) return;
      if (document.documentElement.classList.contains("preloader-skip")) {
        if (pre.parentNode) pre.parentNode.removeChild(pre);
        return;
      }
      var html = document.documentElement;
      html.style.overflow = "hidden";
      window.setTimeout(function () {
        pre.classList.add("is-hiding");
        try { window.localStorage.setItem("goldstone_preloader_ts", String(Date.now())); } catch (e) {}
        html.style.overflow = "";
        window.setTimeout(function () {
          if (pre.parentNode) pre.parentNode.removeChild(pre);
        }, 600);
      }, 2000);
    })();
  </script>
</body>
</html>
