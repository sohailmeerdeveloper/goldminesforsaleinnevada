---
{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Dennis Blancey",
  "jobTitle": "President & Owner",
  "worksFor": {
    "@type": "Organization",
    "name": "Goldstone LLC",
    "url": "{{ site.url }}"
  },
  "telephone": ["{{ site.contact.phones[0] }}", "{{ site.contact.phones[1] }}"],
