{% endblock %}

{% block content %}
<article class="content-page">
  <header class="content-hero on-bg">
    <div class="content-hero__inner">
      <p class="eyebrow">Goldstone LLC &middot; Since 1989</p>
      <h1>About Dennis Blancey and Goldstone LLC</h1>
      <p class="content-hero__lede">Nevada mining property work, public-record documentation, and direct principal contact from offices in Carlin, Golconda, and Carson City.</p>
    </div>
  </header>

  <section class="content-section">
    <div class="content-split">
      <figure class="photo-placeholder" aria-label="Dennis Blancey portrait placeholder">
        <span class="mono">[CLIENT PHOTO &mdash; TBD]</span>
      </figure>
      <div>
        <p class="eyebrow">Principal</p>
        <h2>Dennis Blancey</h2>
        <p class="lede">President and Owner, Goldstone LLC</p>
        <p class="content-copy">Dennis Blancey has worked Nevada mining property since 1989. Goldstone LLC operates from three offices across the state &mdash; Carlin, Golconda, and Carson City &mdash; covering the Carlin Trend, the Battle Mountain&ndash;Eureka belt, and the Humboldt mining districts. The firm focuses on properties with documented USGS or Nevada Bureau of Mines and Geology records, and works directly with serious buyers rather than through intermediaries.</p>
      </div>
    </div>
  </section>

  <section class="content-section content-section--bone" aria-labelledby="offices-title">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Offices</span>
        <h2 id="offices-title">Nevada Contact Points</h2>
      </div>
      <div class="data-card-grid data-card-grid--three">
        <article class="data-card">
          <p class="label">Carlin</p>
          <p class="data-card__value mono numerals-data">Carlin NV 89822</p>
        </article>
        <article class="data-card">
          <p class="label">Golconda</p>
          <p class="data-card__value mono numerals-data">Golconda NV 89414</p>
        </article>
        <article class="data-card">
          <p class="label">Carson City</p>
          <p class="data-card__value mono numerals-data">Carson City NV 89702</p>
        </article>
      </div>
    </div>
  </section>

  <section class="content-section" aria-labelledby="region-title">
    <div class="content-two-column">
      <div>
        <p class="eyebrow">Operating region</p>
        <h2 id="region-title">Northern Nevada Districts</h2>
      </div>
      <div class="data-list">
        <div>
          <h3>Carlin Trend</h3>
          <p>The Carlin area is central to modern Nevada gold exploration and includes documented mines, mineral occurrences, and mining districts tracked by USGS datasets.</p>
        </div>
        <div>
          <h3>Battle Mountain&ndash;Eureka belt</h3>
          <p>The belt is a long-recognized Nevada mineral trend. Goldstone LLC references public geologic and mineral-resource records when presenting property files in this region.</p>
        </div>
        <div>
          <h3>Humboldt mining districts</h3>
          <p>Humboldt County includes historic districts such as Gold Run, where the Adelaide Mine is documented through Mindat and USGS MRDS records.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-cta on-bg" aria-labelledby="about-cta-title">
    <div class="content-cta__inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2 id="about-cta-title">Review the current property files.</h2>
      </div>
      <div class="content-cta__links">
        <a class="btn btn--primary" href="/properties/">View Properties</a>
        <a class="btn btn--ghost" href="/contact/">Contact Dennis Blancey</a>
      </div>
    </div>
  </section>
</article>
{% endblock %}
