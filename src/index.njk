{# ── Contact band ────────────────────────────────────────────────── #}
<section class="contact-band on-bg" aria-labelledby="contact-h2">
  <div class="contact-band__inner">
    <div>
      <span class="eyebrow">Request a property packet</span>
      <h2 id="contact-h2" style="margin-top: var(--s-3)">Inquiries reviewed by Dennis Blancey directly.</h2>
      <p class="lede">For full property files, technical reports, and on-site visit coordination, contact Goldstone LLC at any of the offices below.</p>

      <ul class="contact-channels">
        <li><span class="channel__label">Phone</span><a href="tel:{{ site.contact.phonesTel[0] }}">{{ site.contact.phones[0] }}</a></li>
        <li><span class="channel__label">Phone</span><a href="tel:{{ site.contact.phonesTel[1] }}">{{ site.contact.phones[1] }}</a></li>
        <li><span class="channel__label">Email</span><a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a></li>
        {% for office in site.offices %}
        <li><span class="channel__label">Office</span><span>{{ office.city }}, {{ office.state }} {{ office.postal }}</span></li>
        {% endfor %}
      </ul>
    </div>

    <form class="inquiry-inline" action="/contact/" method="get" aria-label="Quick inquiry">
      <div class="field">
        <label for="inq-name">Name</label>
        <input id="inq-name" name="name" type="text" autocomplete="name" required>
      </div>
      <div class="field">
        <label for="inq-email">Email</label>
        <input id="inq-email" name="email" type="email" autocomplete="email" required>
      </div>
      <div class="field field--full">
        <label for="inq-message">Message</label>
        <textarea id="inq-message" name="message" rows="4" placeholder="Property of interest, timeline, and any specific questions."></textarea>
      </div>
      <div class="actions">
        <button type="submit" class="btn btn--primary">Send inquiry <span class="btn__arrow" aria-hidden="true">&rarr;</span></button>
        <p class="actions__note">Full inquiry form on the <a href="/contact/">contact page</a>.</p>
      </div>
    </form>
  </div>
</section>
